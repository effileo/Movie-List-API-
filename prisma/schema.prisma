// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // No output line here!
}
datasource db {
  provider = "postgresql"
}

model user{
  id             Int      @id @default(autoincrement())
  name           String
  email          String   @unique
  password       String
  bio            String?
  avatarUrl      String?
  watchlistPublic Boolean @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  //relations
  watchListItems        watchListItem[]
  movies                movie[]
  reviews               review[]
  comments              comment[]
  watchlistCommentsSent watchlistComment[]     @relation("WatchlistCommentAuthor")
  watchlistCommentsRecv watchlistComment[]     @relation("WatchlistCommentTarget")
  watchlistLikesGiven   watchlistLike[]        @relation("WatchlistLikeUser")
  watchlistLikesRecv    watchlistLike[]        @relation("WatchlistLikeTarget")
  followers             follow[]               @relation("FollowedUser")
  following             follow[]               @relation("FollowingUser")
  notifications         notification[]         @relation("NotificationTo")
  fromNotifications     notification[]         @relation("NotificationFrom")
  cineMatchLikes        cineMatchLike[]
  cineMatchInvitesSent cineMatchInvite[] @relation("CineMatchInviteFrom")
  cineMatchInvitesRecv cineMatchInvite[] @relation("CineMatchInviteTo")
}

model cineMatchLike {
  userId    Int
  tmdbId    Int
  createdAt DateTime @default(now())
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tmdbId])
  @@index([userId])
  @@index([tmdbId])
}

model cineMatchInvite {
  fromUserId Int
  toUserId   Int
  status     CineMatchInviteStatus @default(PENDING)
  createdAt  DateTime              @default(now())
  fromUser   user                  @relation("CineMatchInviteFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser     user                  @relation("CineMatchInviteTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([toUserId])
  @@index([fromUserId])
}

enum CineMatchInviteStatus {
  PENDING
  ACCEPTED
}

model follow {
  followerId  Int
  followedId  Int
  status      FollowStatus @default(PENDING)
  createdAt   DateTime @default(now())
  follower    user     @relation("FollowingUser", fields: [followerId], references: [id], onDelete: Cascade)
  followed    user     @relation("FollowedUser", fields: [followedId], references: [id], onDelete: Cascade)

  @@id([followerId, followedId])
}

enum FollowStatus {
  PENDING
  ACCEPTED
}

model notification {
  id          String   @id @default(uuid())
  userId      Int
  type        NotificationType
  fromUserId  Int?
  data        Json?    // For extra info like movieId or commentId
  message     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        user     @relation("NotificationTo", fields: [userId], references: [id], onDelete: Cascade)
  fromUser    user?    @relation("NotificationFrom", fields: [fromUserId], references: [id], onDelete: SetNull)
}

enum NotificationType {
  FOLLOW_REQUEST
  FOLLOW_ACCEPTED
  LIKE_WATCHLIST
  COMMENT_WATCHLIST
}
model movie{
  id          String   @id @default(uuid())
  tmdbId      Int?     @unique
  title       String
  year        Int
  genre       String[] @default([])
  runTime     Int?
  Overview    String?
  posterPath  String?
  backdropPath String?
  createdAt   DateTime @default(now())
  createdBy   Int
  //relations
  creator user @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  watchListItems watchListItem[]
  reviews        review[]
  comments       comment[]
}
model watchListItem{
  id String @id @default(uuid())
  userId Int
  movieId String
  status WatchListStatus @default(PLANNED)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rating Int?
  notes String?
  //relations
  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])

}
enum WatchListStatus{
  PLANNED
  WATCHING
  COMPLETED
  DROPPED
}

model review{
  id        String   @id @default(uuid())
  userId    Int
  movieId   String
  rating    Int
  text      String?
  createdAt DateTime @default(now())
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie     movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  @@unique([userId, movieId])
}

model comment{
  id        String   @id @default(uuid())
  userId    Int
  movieId   String
  text      String
  createdAt DateTime @default(now())
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie     movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
}

model watchlistComment{
  id           String   @id @default(uuid())
  userId       Int
  targetUserId Int
  text         String
  createdAt    DateTime @default(now())
  user         user     @relation("WatchlistCommentAuthor", fields: [userId], references: [id], onDelete: Cascade)
  targetUser   user     @relation("WatchlistCommentTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
}

model watchlistLike{
  userId       Int
  targetUserId Int
  createdAt    DateTime @default(now())
  user         user     @relation("WatchlistLikeUser", fields: [userId], references: [id], onDelete: Cascade)
  targetUser   user     @relation("WatchlistLikeTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  @@id([userId, targetUserId])
}
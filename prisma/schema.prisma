// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // No output line here!
}
datasource db {
  provider = "postgresql"
}

model user{
  id             Int      @id @default(autoincrement())
  name           String
  email          String   @unique
  password       String
  bio            String?
  avatarUrl      String?
  watchlistPublic Boolean @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  //relations
  watchListItems watchListItem[]
  movies         movie[]
  reviews        review[]
  comments       comment[]
}
model movie{
  id          String   @id @default(uuid())
  tmdbId      Int?     @unique
  title       String
  year        Int
  genre       String[] @default([])
  runTime     Int?
  Overview    String?
  posterPath  String?
  backdropPath String?
  createdAt   DateTime @default(now())
  createdBy   Int
  //relations
  creator user @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  watchListItems watchListItem[]
  reviews        review[]
  comments       comment[]
}
model watchListItem{
  id String @id @default(uuid())
  userId Int
  movieId String
  status WatchListStatus @default(PLANNED)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rating Int?
  notes String?
  //relations
  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])

}
enum WatchListStatus{
  PLANNED
  WATCHING
  COMPLETED
  DROPPED
}

model review{
  id        String   @id @default(uuid())
  userId    Int
  movieId   String
  rating    Int
  text      String?
  createdAt DateTime @default(now())
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie     movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  @@unique([userId, movieId])
}

model comment{
  id        String   @id @default(uuid())
  userId    Int
  movieId   String
  text      String
  createdAt DateTime @default(now())
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie     movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
}